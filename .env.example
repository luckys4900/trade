# API Keys and Secrets (NEVER commit actual values)
OPENROUTER_API_KEY=your_openrouter_api_key_here
GLM_API_KEY=your_glm_api_key_here
OLLAMA_HOST=http://localhost:11434

# Hyperliquid Trading API (Production)
HYPERLIQUID_API_KEY=your_hyperliquid_api_key_here
HYPERLIQUID_SECRET_KEY=your_hyperliquid_secret_key_here
HYPERLIQUID_WALLET_ADDRESS=your_wallet_address_here

# Congress.gov API (Regulatory Monitoring)
CONGRESS_API_KEY=your_congress_api_key_here

# Trading Configuration
TRADING_ENV=development
BASE_POSITION_SIZE=1.0
MAX_POSITION_SIZE=10.0
RISK_LIMIT=0.02

# Production PC Configuration (本番PC設定)
PRODUCTION_HOST=your_production_pc_hostname
PRODUCTION_USER=your_username
PRODUCTION_PORT=22
PRODUCTION_PYTHON_PATH=/usr/bin/python3
PRODUCTION_DATA_DIR=/home/user/trade/data
PRODUCTION_LOG_DIR=/home/user/trade/logs

# Backup and Versioning
BACKUP_RETENTION_DAYS=30
VERSION_TAG=v3.0.0-development

# Monitoring and Alerts
ALERT_EMAIL=your_email@example.com
SLACK_WEBHOOK_URL=your_slack_webhook_url
ENABLE_HEALTH_CHECKS=true