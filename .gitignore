# Byte-compiled / caches
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
.venv/
venv/
ENV/

# Local secrets (never push keys)
.env
.env.*
!.env.example

# Cursor / Claude local worktrees (duplicate trees; not source of truth)
.claude/worktrees/

# Editor / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Generated logs (keep repo history for config/code, not hourly log churn)
logs/*
!logs/.gitkeep

# Runtime outputs (bots rewrite these; version config via config.json / whale_wallets.json)
macro_state.json
trade_state_unified.json
state_tmp.json
whale_signal.json
whale_ranking_cache.json
SYSTEM/whale_ranking_cache.json
inflow_short_signal.json
kronos_contrarian_signal.json
kronos_signal.json
