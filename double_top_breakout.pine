//@version=5
strategy("Double Top Breakout Strategy - Optimized", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, commission_type=strategy.commission.percent, commission_value=0.035, slippage=0.1)

// ==================== Parameters (OOS Optimized) ====================
pivotLength = input.int(10, "Pivot Length", minval=3, maxval=15)
priceTolerance = input.float(2.0, "Price Tolerance (%)", minval=0.5, maxval=5.0) / 100
minHighCount = input.int(2, "Min High Count (2=Double Top)", minval=2, maxval=3)

bbPeriod = input.int(20, "BB Period", minval=10, maxval=30)
bbStd = input.float(2.0, "BB Std Dev", minval=1.0, maxval=3.0)

atrPeriod = input.int(14, "ATR Period", minval=10, maxval=20)
atrSLMult = input.float(2.0, "SL ATR Mult", minval=1.0, maxval=4.0)
atrTPMult = input.float(4.0, "TP ATR Mult", minval=2.0, maxval=6.0)

maxHoldBars = input.int(20, "Max Hold Bars", minval=5, maxval=30)

useVolFilter = input.bool(false, "Use Volume Filter")
volumeMult = input.float(1.0, "Volume Spike Threshold", minval=1.0, maxval=4.0)
useBBFilter = input.bool(true, "Use BB Filter")
useRegimeFilter = input.bool(true, "Use Volatility Regime Filter")
regimeLookback = input.int(50, "Regime Lookback", minval=30, maxval=100)
useLowsRising = input.bool(true, "Use Lows Rising Filter")
pivotMemoryBars = input.int(120, "Pivot Memory Bars", minval=50, maxval=200)

// ==================== Indicators ====================
atr = ta.atr(atrPeriod)

bbMiddle = ta.sma(close, bbPeriod)
bbUpper = bbMiddle + bbStd * ta.stdev(close, bbPeriod)
bbLower = bbMiddle - bbStd * ta.stdev(close, bbPeriod)
bbWidth = (bbUpper - bbLower) / bbMiddle

volSMA = ta.sma(volume, 20)

pivotHigh = ta.pivothigh(high, pivotLength, pivotLength)
pivotLow = ta.pivotlow(low, pivotLength, pivotLength)

// ==================== Double Top Detection ====================
var float[] recentHighs = array.new_float(0)
var int[] highBarIndices = array.new_int(0)

if not na(pivotHigh)
    array.push(recentHighs, pivotHigh)
    array.push(highBarIndices, bar_index)

if array.size(highBarIndices) > 0
    oldestIdx = array.get(highBarIndices, 0)
    if bar_index - oldestIdx > pivotMemoryBars
        array.shift(recentHighs)
        array.shift(highBarIndices)

doubleTopCondition = false
avgHighPrice = 0.0

if array.size(recentHighs) >= minHighCount
    lastHighs = array.new_float(0)
    for i = 0 to minHighCount - 1
        if i < array.size(recentHighs)
            array.unshift(lastHighs, array.get(recentHighs, array.size(recentHighs) - 1 - i))

    if array.size(lastHighs) >= minHighCount
        minHigh = array.min(lastHighs)
        maxHigh = array.max(lastHighs)
        avgHighPrice := array.avg(lastHighs)
        highPriceRange = (maxHigh - minHigh) / avgHighPrice

        priceBandValid = highPriceRange <= priceTolerance * 2
        nearHighBand = close >= avgHighPrice * (1 - priceTolerance) and close <= avgHighPrice * (1 + priceTolerance)

        lowsRising = true
        if useLowsRising and array.size(highBarIndices) >= 2
            for i = 1 to min(array.size(highBarIndices) - 1, minHighCount - 1)
                prevBarIdx = array.get(highBarIndices, i)
                currBarIdx = array.get(highBarIndices, i - 1)
                prevLow = ta.lowest(low, prevBarIdx - pivotLength * 2, prevBarIdx)
                currLow = ta.lowest(low, currBarIdx - pivotLength * 2, currBarIdx)
                if currLow <= prevLow
                    lowsRising := false
                    break

        doubleTopCondition := priceBandValid and nearHighBand and lowsRising

// ==================== Filters ====================
volumeCondition = not useVolFilter or (volume > volSMA * volumeMult)

bbCondition = not useBBFilter or (close > bbUpper and bbWidth > bbWidth[1])

volPct = 0.0
if useRegimeFilter
    absReturns = array.new_float(0)
    for i = 0 to regimeLookback - 1
        if bar_index - i > 0
            array.push(absReturns, math.abs(close[bar_index - i] - close[bar_index - i - 1]) / close[bar_index - i - 1] * 100)
    if array.size(absReturns) > 0
        currentVol = math.abs(close - close[1]) / close[1] * 100
        higherCount = 0
        for i = 0 to array.size(absReturns) - 1
            if currentVol >= array.get(absReturns, i)
                higherCount += 1
        volPct := higherCount / array.size(absReturns) * 100

regimeCondition = not useRegimeFilter or (volPct >= 35 and volPct <= 80)

// ==================== Entry ====================
longCondition = doubleTopCondition and volumeCondition and bbCondition and regimeCondition

var int entryBar = na

if longCondition and strategy.position_size == 0
    entryBar := bar_index

slPrice = strategy.position_avg_price - atr * atrSLMult
tpPrice = strategy.position_avg_price + atr * atrTPMult

if strategy.position_size > 0 and bar_index - entryBar >= maxHoldBars
    strategy.close("Long Exit", comment="Max Hold")

if longCondition and strategy.position_size == 0
    strategy.entry("Long", strategy.long, comment="DT Breakout")

if strategy.position_size > 0
    strategy.exit("Exit", "Long", stop=slPrice, limit=tpPrice)

// ==================== Plots ====================
plot(pivotHigh, "Pivot High", color=color.red, style=plot.style_circles, offset=-pivotLength)
plot(pivotLow, "Pivot Low", color=color.green, style=plot.style_circles, offset=-pivotLength)
plot(doubleTopCondition ? avgHighPrice : na, "DT Level", color=color.purple, style=plot.style_linebr, linewidth=2)
plot(bbUpper, "BB Upper", color=color.blue, linewidth=1)
plot(bbMiddle, "BB Middle", color=color.orange, linewidth=1)
plot(bbLower, "BB Lower", color=color.blue, linewidth=1)
plotshape(longCondition, "Buy Signal", shape.triangleup, location.belowbar, color=color.lime, size=size.small, text="BUY")
